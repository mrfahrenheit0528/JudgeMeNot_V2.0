{% extends "base.html" %}
{% block title %}Live Leaderboard{% endblock %}
{% block content %}

<style>
    /* Winner Styles (Only applied when no round is active) */
    .rank-1 { background-color: #fffde7 !important; border-left: 8px solid #ffd700; } /* Gold */
    .rank-2 { background-color: #f5f5f5 !important; border-left: 8px solid #c0c0c0; } /* Silver */
    .rank-3 { background-color: #fff3e0 !important; border-left: 8px solid #cd7f32; } /* Bronze */
    
    /* Make the top 3 rows pop a bit more */
    .rank-1 td, .rank-2 td, .rank-3 td {
        vertical-align: middle;
    }
</style>

<div class="container mt-4">

    {% if event %}
        <h1 class="text-center fw-bold">{{ event.name }}</h1>
        <h4 class="text-center text-muted mb-4">
            {% if active_round %}
                Current Stage: <span class="text-primary">{{ active_round.difficulty }}</span>
            {% else %}
                Official Standings
            {% endif %}
        </h4>
    
        <div class="card shadow">
            <div class="card-body p-0 table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 80px;">Rank</th>
                            <th class="text-start">School</th>
                            
                            <!-- DYNAMIC ROUND HEADERS -->
                            {% for r in rounds %}
                                <th class="{% if active_round and r.id == active_round.id %}bg-success{% endif %}">
                                    {{ r.difficulty }}
                                </th>
                            {% endfor %}
                            
                            {% if not is_hybrid_final %}
                                <th class="bg-warning text-dark fw-bold">TOTAL</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for rank in rankings %}
                        
                        <!-- Determine Row Class for Winners (Only if no active round) -->
                        {% set row_class = "" %}
                        {% if not active_round %}
                            {% if loop.index == 1 %}{% set row_class = "rank-1" %}
                            {% elif loop.index == 2 %}{% set row_class = "rank-2" %}
                            {% elif loop.index == 3 %}{% set row_class = "rank-3" %}
                            {% endif %}
                        {% endif %}

                        <tr class="{{ row_class }}">
                            <!-- RANK COLUMN -->
                            <td class="fw-bold fs-5">
                                {% if rank.is_competing %}
                                    <span class="text-success fs-3">&bull;</span> <!-- Green Dot (Live) -->
                                {% else %}
                                    {% if not active_round and loop.index <= 3 %}
                                        <!-- Medal Icons for Final Result -->
                                        {% if loop.index == 1 %}🥇{% elif loop.index == 2 %}🥈{% elif loop.index == 3 %}🥉{% endif %}
                                    {% else %}
                                        #{{ loop.index }}
                                    {% endif %}
                                {% endif %}
                            </td>
                            
                            <!-- NAME -->
                            <td class="text-start fw-bold">{{ rank.name }}</td>
                            
                            <!-- ROUND SCORES -->
                            {% for r in rounds %}
                                <td class="text-muted">
                                    {{ rank.breakdown.get(r.difficulty, '-') }}
                                </td>
                            {% endfor %}
                            
                            <!-- TOTAL (Hidden in Final Phase) -->
                            {% if not is_hybrid_final %}
                                <td class="bg-warning bg-opacity-25 fw-bold fs-4">
                                    {{ rank.total }}
                                </td>
                            {% endif %}
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="100%" class="text-muted py-4">Waiting for scores...</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <!-- Fast refresh when live -->
        <meta http-equiv="refresh" content="3">

    {% else %}
        <!-- NO EVENT ACTIVE STATE -->
        <div class="alert alert-warning text-center shadow-sm p-5 mt-5" role="alert">
            <h1 class="display-1 mb-3"><i class="fas fa-calendar-times text-warning"></i></h1>
            <h2 class="alert-heading fw-bold">No Active Event</h2>
            <p class="lead">There is currently no active Quiz Bee event being broadcasted.</p>
            <hr class="w-50 mx-auto my-4">
            <p class="mb-0 text-muted">Please check back later or contact the administrator.</p>
        </div>
        <!-- Slower refresh when idle to save resources -->
        <meta http-equiv="refresh" content="10">
    {% endif %}

</div>
{% endblock %}
