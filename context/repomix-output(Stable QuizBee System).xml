                    <td class="text-center">
                        <!-- Links to management pages -->
                        <a href="{{ url_for('views.round_setup', event_id=event.id) }}" 
                           class="btn btn-sm btn-info me-2" title="Define Rounds">Rounds</a>
                        <a href="{{ url_for('views.school_registration', event_id=event.id) }}" class="btn btn-sm btn-warning" title="Register Schools">Schools</a>
                    </td>

                    <td class="text-center">
                        <!-- TOGGLE ACTIVE STATUS -->
                        {% if event.is_active %}
                            <!-- DEACTIVATE BUTTON -->
                            <form method="POST" action="{{ url_for('views.event_registration') }}" class="d-inline">
                                <input type="hidden" name="action" value="deactivate">
                                <input type="hidden" name="event_id" value="{{ event.id }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" 
                                        onclick="return confirm('Are you sure you want to deactivate {{ event.name }}? No event will be live.');">
                                    Deactivate
                                </button>
                            </form>
                        {% else %}
                            <!-- ACTIVATE BUTTON -->
                            <form method="POST" action="{{ url_for('views.event_registration') }}" class="d-inline">
                                <input type="hidden" name="action" value="set_active">
                                <input type="hidden" name="event_id" value="{{ event.id }}">
                                <button type="submit" class="btn btn-sm btn-dark" 
                                        onclick="return confirm('Set {{ event.name }} as active? All other events will be deactivated.');">
                                    Activate
                                </button>
                            </form>
                        {% endif %}

                        <!-- Edit Button -->
                        <a href="{{ url_for('views.edit_event', event_id=event.id) }}" class="btn btn-sm btn-outline-secondary ms-2">Edit</a>

                        <!-- Delete Button -->
                        <form method="POST" action="{{ url_for('views.delete_event', event_id=event.id) }}" class="d-inline ms-1">
                            <button type="submit" class="btn btn-sm btn-danger" 
                                    onclick="return confirm('Are you sure? This will delete all rounds and scores for this event.');">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="alert alert-info mt-5">
            No events have been created yet. Use the form above to create your first event.
        </div>
    {% endif %}
</div>

{% endblock %}
</file>

<file path="website/templates/admin/register_user.html">
{% extends "base.html" %}
{% block title %}Manage Users{% endblock %}

{% block content %}
<div class="container mt-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">User Management</h2>
        <a href="{{ url_for('views.admin_dashboard') }}" class="btn btn-outline-secondary btn-sm">
            &larr; Dashboard
        </a>
    </div>

    <div class="row">
        <!-- LEFT: Create User Form -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-success h-100">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>Create New Account</h5>
                </div>
                
                <div class="card-body p-4">
                    <form method="POST">
                        <!-- Role Selection -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Account Role</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="radio" class="btn-check" name="role" id="role_tabulator" value="tabulator" checked>
                                    <label class="btn btn-outline-primary w-100" for="role_tabulator">Tabulator</label>
                                </div>
                                <div class="col-6">
                                    <input type="radio" class="btn-check" name="role" id="role_admin" value="admin">
                                    <label class="btn btn-outline-danger w-100" for="role_admin">Admin</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Username</label>
                            <input type="text" class="form-control" name="username" placeholder="e.g. tab_main" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">First Name</label>
                            <input type="text" class="form-control" name="first_name" placeholder="e.g. Juan Dela Cruz">
                            <div class="form-text">Used for signatures in reports.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <input type="text" class="form-control" name="password" placeholder="Set initial password" required>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: Existing Users List -->
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-users me-2"></i>Existing Accounts</h5>
                </div>
                <div class="card-body p-0 table-responsive">
                    <table class="table table-striped table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Username</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                            <tr>
                                <td class="fw-bold">{{ user.username }}</td>
                                <td>{{ user.first_name if user.first_name else '-' }}</td>
                                <td>
                                    {% if user.role == 'admin' %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% else %}
                                        <span class="badge bg-primary">Tabulator</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <!-- Edit Button -->
                                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editUserModal{{ user.id }}">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </td>
                            </tr>

                            <!-- EDIT USER MODAL -->
                            <div class="modal fade" id="editUserModal{{ user.id }}" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Edit User: {{ user.username }}</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form method="POST" action="{{ url_for('views.edit_user', user_id=user.id) }}">
                                            <div class="modal-body">
                                                <div class="mb-3">
                                                    <label class="form-label">Username</label>
                                                    <input type="text" name="username" class="form-control" value="{{ user.username }}" required>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label">First Name</label>
                                                    <input type="text" name="first_name" class="form-control" value="{{ user.first_name or '' }}">
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label text-danger fw-bold">Reset Password</label>
                                                    <input type="text" name="password" class="form-control" placeholder="Leave empty to keep current">
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-primary">Save Changes</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            {% else %}
                            <tr><td colspan="4" class="text-center py-4">No users found.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="website/templates/admin/round_setup.html">
{% extends "base.html" %}
{% block title %}Round Configuration{% endblock %}

{% block content %}
<div class="container mt-4">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Setup Rounds</h2>
            <h5 class="text-muted">Event: <strong>{{ event.name }}</strong></h5>
        </div>
        <a href="{{ url_for('views.event_registration') }}" class="btn btn-outline-secondary">
            &larr; Back to Events List
        </a>
    </div>

    <div class="row">
        <!-- LEFT COLUMN: Add Round Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-primary mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-plus-circle"></i> Add New Round
                </div>
                <div class="card-body">
                    <form method="POST">
                        
                        <!-- Order -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Order #</label>
                            <input type="number" name="round_number" class="form-control" placeholder="e.g. 1" required>
                            <div class="form-text">1=First round, 2=Second...</div>
                        </div>

                        <!-- Difficulty Name -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Round Name</label>
                            <input type="text" name="difficulty" class="form-control" list="difficultyOptions" placeholder="Type or select..." required>
                            <datalist id="difficultyOptions">
                                <option value="Easy">
                                <option value="Average">
                                <option value="Difficult">
                                <option value="Clincher">
                            </datalist>
                        </div>

                        <!-- Points -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Points per Question</label>
                            <div class="input-group">
                                <span class="input-group-text">Pts</span>
                                <input type="number" name="points" class="form-control" placeholder="e.g. 5" required>
                            </div>
                        </div>

                        <!-- Questions Count -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Total Questions</label>
                            <div class="input-group">
                                <span class="input-group-text">Qty</span>
                                <input type="number" name="total_questions" class="form-control" placeholder="e.g. 10" required>
                            </div>
                        </div>
                        
                        <!-- Qualifiers -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">Qualifiers (Advance)</label>
                            <input type="number" name="qualifying_count" class="form-control" placeholder="e.g. 10 (0 = All)">
                            <div class="form-text">Top N schools to advance.</div>
                        </div>

                        <!-- Is Final -->
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="is_final" name="is_final">
                            <label class="form-check-label fw-bold" for="is_final">Is Final Round?</label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Save Round</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: List of Rounds -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    Current Rounds Configuration
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle text-center">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th class="text-start">Round Name</th>
                                <th>Points</th>
                                <th>Questions</th>
                                <th>Qualifiers</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for round in rounds %}
                            <tr class="{% if round.is_final %}table-warning{% endif %}">
                                <td class="fw-bold">{{ round.number }}</td>
                                <td class="text-start">
                                    {{ round.difficulty }}
                                    {% if round.is_final %}<span class="badge bg-warning text-dark ms-1">FINAL</span>{% endif %}
                                </td>
                                <td><span class="badge bg-info text-dark">{{ round.points }} pts</span></td>
                                <td>{{ round.total_questions }}</td>
                                <td>{{ round.qualifying_count if round.qualifying_count > 0 else "All" }}</td>
                                <td>
                                    <!-- EDIT BUTTON -->
                                    <button type="button" class="btn btn-sm btn-outline-primary me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editRoundModal{{ round.id }}">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <!-- DELETE BUTTON -->
                                    <form method="POST" action="{{ url_for('views.delete_round', round_id=round.id) }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this round?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            <!-- EDIT MODAL FOR THIS ROUND -->
                            <div class="modal fade" id="editRoundModal{{ round.id }}" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content text-start">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Edit Round: {{ round.difficulty }}</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form method="POST" action="{{ url_for('views.edit_round', round_id=round.id) }}">
                                            <div class="modal-body">
                                                
                                                <div class="row g-2 mb-3">
                                                    <div class="col-4">
                                                        <label class="form-label">Order #</label>
                                                        <input type="number" name="round_number" class="form-control" value="{{ round.number }}" required>
                                                    </div>
                                                    <div class="col-8">
                                                        <label class="form-label">Round Name</label>
                                                        <input type="text" name="difficulty" class="form-control" value="{{ round.difficulty }}" required>
                                                    </div>
                                                </div>

                                                <div class="row g-2 mb-3">
                                                    <div class="col-6">
                                                        <label class="form-label">Points</label>
                                                        <input type="number" name="points" class="form-control" value="{{ round.points }}" required>
                                                    </div>
                                                    <div class="col-6">
                                                        <label class="form-label">Items</label>
                                                        <input type="number" name="total_questions" class="form-control" value="{{ round.total_questions }}" required>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label">Qualifiers (Advancing)</label>
                                                    <input type="number" name="qualifying_count" class="form-control" value="{{ round.qualifying_count }}">
                                                </div>

                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input" name="is_final" id="editFinal{{ round.id }}" 
                                                           {% if round.is_final %}checked{% endif %}>
                                                    <label class="form-check-label" for="editFinal{{ round.id }}">Is Final Round?</label>
                                                </div>

                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-primary">Save Changes</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <em>No rounds created yet.</em>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="website/templates/admin/school_registration.html">
{% extends "base.html" %}
{% block title %}School Registration{% endblock %}

{% block content %}
<div class="container mt-4">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Register Schools</h2>
            <h5 class="text-muted">Event: <strong>{{ event.name }}</strong></h5>
        </div>
        <a href="{{ url_for('views.event_registration') }}" class="btn btn-outline-secondary">
            &larr; Back to Events
        </a>
    </div>

    <div class="row">
        <!-- LEFT COLUMN: Registration Form -->
        <div class="col-md-4">
            <div class="card shadow-sm border-primary mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-school me-2"></i> Add Candidate / School
                </div>
                <div class="card-body">
                    <form method="POST">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">School / Candidate Name</label>
                            <input type="text" name="school_name" class="form-control" placeholder="e.g. Blue Team" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Assign Tabulator</label>
                            <select name="tabulator_id" class="form-select" required>
                                <option value="" disabled selected>-- Select an Account --</option>
                                
                                {% for tab in all_tabulators %}
                                    <!-- Disable if assigned to another school IN THIS EVENT -->
                                    {% set is_assigned_here = false %}
                                    {% for s in schools %}
                                        {% if s.user_id == tab.id %}
                                            {% set is_assigned_here = true %}
                                        {% endif %}
                                    {% endfor %}

                                    <option value="{{ tab.id }}">
                                        {{ tab.username }} 
                                        {% if tab.first_name %}({{ tab.first_name }}){% endif %}
                                    </option>
                                {% else %}
                                    <option disabled>No tabulator accounts found.</option>
                                {% endfor %}
                            </select>
                            <div class="form-text small">
                                Need a new tabulator? 
                                <a href="{{ url_for('views.register_user') }}">Create Account</a>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Add to Event</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: List of Registered Schools -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header">
                    Registered Schools ({{ schools|length }})
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>School Name</th>
                                <th>Assigned Tabulator</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for school in schools %}
                            <tr>
                                <td class="fw-bold">{{ school.name }}</td>
                                <td>
                                    {% if school.tabulator %}
                                        <span class="badge bg-light text-dark border">
                                            <i class="fas fa-user me-1"></i> 
                                            {{ school.tabulator.username }}
                                            {% if school.tabulator.first_name %}
                                                ({{ school.tabulator.first_name }})
                                            {% endif %}
                                        </span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Unassigned</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    
                                    <!-- EDIT BUTTON (Triggers Modal) -->
                                    <button type="button" class="btn btn-sm btn-outline-primary me-1" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#editSchoolModal{{ school.id }}">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <!-- DELETE BUTTON -->
                                    <form method="POST" action="{{ url_for('views.delete_school', school_id=school.id) }}" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                onclick="return confirm('Remove {{ school.name }} from this event?');">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            <!-- EDIT MODAL FOR THIS SCHOOL -->
                            <div class="modal fade" id="editSchoolModal{{ school.id }}" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Edit School Details</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <form method="POST" action="{{ url_for('views.edit_school', school_id=school.id) }}">
                                            <div class="modal-body">
                                                
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">School Name</label>
                                                    <input type="text" name="school_name" value="{{ school.name }}" class="form-control" required>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">Assigned Tabulator</label>
                                                    <select name="tabulator_id" class="form-select">
                                                        {% for t in all_tabulators %}
                                                            <option value="{{ t.id }}" {% if school.user_id == t.id %}selected{% endif %}>
                                                                {{ t.username }} 
                                                                {% if t.first_name %}({{ t.first_name }}){% endif %}
                                                            </option>
                                                        {% endfor %}
                                                    </select>
                                                </div>

                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-primary">Save Changes</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            {% else %}
                            <tr>
                                <td colspan="3" class="text-center text-muted py-5">
                                    <em>No schools registered yet.</em>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="website/templates/tabulator/scoring.html">
{% extends "base.html" %}
{% block title %}Scoring - {{ round.difficulty }}{% endblock %}

{% block content %}
<div class="container mb-5 mt-4">
    
    <!-- Header Info -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">{{ school.name }}</h2>
            <span class="badge bg-secondary">{{ round.difficulty }} Round</span>
            <span class="badge bg-info text-dark">{{ round.points }} Pts / Question</span>
        </div>
        <a href="{{ url_for('views.tabulator_dashboard') }}" class="btn btn-outline-dark btn-sm">
            &larr; Back to Dashboard
        </a>
    </div>

    <form method="POST">
        
        <!-- LIST LAYOUT (Single Column) -->
        <div class="row">
            <div class="col-12">
                {% for q in range(1, total_questions+1) %}
                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-body d-flex justify-content-between align-items-center p-3">
                        
                        <!-- LEFT SIDE: Question Number & Status -->
                        <div class="d-flex align-items-center">
                            <h5 class="mb-0 fw-bold me-3">Question #{{ q }}</h5>
                            
                            <!-- Visual indicator of current state -->
                            {% if score_map.get(q) == True %}
                                <span class="badge bg-success"><i class="fas fa-check"></i> Correct</span>
                            {% elif score_map.get(q) == False %}
                                <span class="badge bg-danger"><i class="fas fa-times"></i> Wrong</span>
                            {% else %}
                                <span class="badge bg-light text-dark border">Pending</span>
                            {% endif %}
                        </div>

                        <!-- RIGHT SIDE: Toggle Buttons (Parallel) -->
                        <div class="btn-group" role="group" aria-label="Scoring toggle">
                            
                            <!-- CORRECT BUTTON -->
                            <input type="radio" class="btn-check" name="question_{{ q }}" id="q{{ q }}_correct" value="correct"
                                {% if score_map.get(q) == True %}checked{% endif %}>
                            <label class="btn btn-outline-success fw-bold px-4" for="q{{ q }}_correct">
                                Correct
                            </label>

                            <!-- WRONG BUTTON -->
                            <input type="radio" class="btn-check" name="question_{{ q }}" id="q{{ q }}_wrong" value="wrong"
                                {% if score_map.get(q) == False %}checked{% endif %}>
                            <label class="btn btn-outline-danger fw-bold px-4" for="q{{ q }}_wrong">
                                Wrong
                            </label>
                        
                        </div>

                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Floating Submit Button Area -->
        <div class="fixed-bottom bg-white border-top p-3 shadow">
            <div class="container">
                <div class="d-grid gap-2">
